{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {{- range .Site.Pages }}
    {{- if and (not .Params.private) (not .Params.noindex) }}
    <url>
      <loc>{{ .Permalink }}</loc>
      <lastmod>{{ or .Lastmod .Date | time.Format "2006-01-02T15:04:05Z07:00" }}</lastmod>
      <changefreq>{{ if .IsHome }}daily{{ else if eq .Kind "taxonomy" }}weekly{{ else if eq .Kind "term" }}weekly{{ else }}weekly{{ end }}</changefreq>
      <priority>{{ if .IsHome }}1.0{{ else if eq .Kind "taxonomy" }}0.8{{ else if eq .Kind "term" }}0.8{{ else if eq .Kind "section" }}0.8{{ else }}0.7{{ end }}</priority>
    </url>
    {{- end }}
  {{- end }}
</urlset>